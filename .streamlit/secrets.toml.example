# Kopiere diese Datei nach .streamlit/secrets.toml und fülle die Werte aus.
# In Streamlit Community Cloud dieselben Schlüssel ins "Secrets"-Feld eintragen.

# Passwort für den Zugang zur App
APP_PASSWORD = "dein-sicheres-passwort"

# Anthropic / Claude (für den KI-Mentor)
ANTHROPIC_API_KEY = "sk-ant-..."
# Optional: Modell überschreiben (Default: claude-opus-4-8)
# MENTOR_MODEL = "claude-sonnet-4-6"

# Supabase (Projekt-URL + service_role Key aus Project Settings -> API)
SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SUPABASE_KEY = "service_role-key-hier"
